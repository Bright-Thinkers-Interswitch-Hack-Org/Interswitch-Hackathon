# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# JWT Secret (generate a random string)
JWT_SECRET=your-jwt-secret-change-this

# Interswitch API (for WhatsApp OTP)
INTERSWITCH_CLIENT_ID=your-interswitch-client-id
INTERSWITCH_CLIENT_SECRET=your-interswitch-client-secret
INTERSWITCH_BASE_URL=https://qa.interswitchng.com
INTERSWITCH_TERMINAL_ID=your-terminal-id

# Server
PORT=3001
NODE_ENV=development
